GEMINI_API_KEY=isi_api_key_gemini_kamu
GEMINI_MODEL=gemini-2.5-flash

# Gunakan port berbeda untuk tiap peserta saat deploy di VPS yang sama.
# Contoh: peserta 1 = 3001, peserta 2 = 3002, dan seterusnya.
PORT=3000

# Jika PORT sedang dipakai, aplikasi mencoba port berikutnya sampai batas ini.
PORT_RANGE=50